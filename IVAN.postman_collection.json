{
  "info": {
    "_postman_id": "0412a9ab-1cbb-47cd-bf9d-771718d5d895",
    "name": "IVAN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53127702"
  },
  "item": [
    {
      "name": "test_postman_validation",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const config = {\r",
              "    request_key:    \"db\",\r",
              "    provider_code:  \"PRV-001\",\r",
              "    phic_token:     \"your-phic-token-here\",\r",
              "    pHciAccreNo:    \"HCI-12345\",\r",
              "    report_tagging: \"1\",\r",
              "    report_status:  \"first_validation\",\r",
              "    start_date:     \"2025-01-01\",\r",
              "    end_date:       \"2025-12-31\",\r",
              "    case_number:    [\"CN-2025-001\"],\r",
              "};\r",
              "\r",
              "if (config.report_status === \"batch_validation\" && config.case_number.length === 1) {\r",
              "    console.warn(\"[WARNING] batch_validation expects multiple case_numbers, only 1 provided.\");\r",
              "}\r",
              "\r",
              "if (config.report_status === \"first_validation\" && config.case_number.length > 1) {\r",
              "    console.warn(\"[WARNING] first_validation expects 1 case_number, but \" + config.case_number.length + \" were provided.\");\r",
              "}\r",
              "\r",
              "if (config.report_tagging === \"1\" && config.report_status === \"batch_validation\") {\r",
              "    console.warn(\"[WARNING] T1 + batch_validation = SUBMISSION run. Ensure records are validated first.\");\r",
              "}\r",
              "\r",
              "const body = {\r",
              "    request_key:    config.request_key,\r",
              "    provider_code:  config.provider_code,\r",
              "    phic_token:     config.phic_token,\r",
              "    pHciAccreNo:    config.pHciAccreNo,\r",
              "    report_tagging: config.report_tagging,\r",
              "    report_status:  config.report_status,\r",
              "    start_date:     config.start_date,\r",
              "    end_date:       config.end_date,\r",
              "    case_number:    config.case_number,\r",
              "};\r",
              "\r",
              "pm.request.body.update({\r",
              "    mode: \"raw\",\r",
              "    raw: JSON.stringify(body, null, 2),\r",
              "    options: { raw: { language: \"json\" } }\r",
              "});\r",
              "\r",
              "console.log(\"[PRE-REQUEST] Payload set:\", JSON.stringify(body, null, 2));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    pm.expect(() => pm.response.json()).to.not.throw();\r",
              "});\r",
              "\r",
              "pm.test(\"Response has all required fields\", function () {\r",
              "    pm.expect(body).to.have.property(\"payload_valid\");\r",
              "    pm.expect(body).to.have.property(\"total_errors\");\r",
              "    pm.expect(body).to.have.property(\"total_warnings\");\r",
              "    pm.expect(body).to.have.property(\"total_passed\");\r",
              "    pm.expect(body).to.have.property(\"errors\");\r",
              "    pm.expect(body).to.have.property(\"warnings\");\r",
              "    pm.expect(body).to.have.property(\"passed\");\r",
              "    pm.expect(body).to.have.property(\"received_payload\");\r",
              "});\r",
              "\r",
              "pm.test(\"Payload is valid (no errors found)\", function () {\r",
              "    pm.expect(body.payload_valid).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"No errors in payload\", function () {\r",
              "    pm.expect(body.errors).to.be.an(\"array\");\r",
              "    pm.expect(body.total_errors).to.equal(0);\r",
              "});\r",
              "\r",
              "pm.test(\"At least one field passed validation\", function () {\r",
              "    pm.expect(body.total_passed).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Received payload contains all expected fields\", function () {\r",
              "    const p = body.received_payload;\r",
              "    [\"request_key\", \"provider_code\", \"phic_token\", \"pHciAccreNo\",\r",
              "     \"report_tagging\", \"report_status\", \"start_date\", \"end_date\", \"case_number\"]\r",
              "    .forEach(function (field) {\r",
              "        pm.expect(p, \"Missing field: \" + field).to.have.property(field);\r",
              "    });\r",
              "});\r",
              "\r",
              "console.log(\"Payload Valid  : \" + body.payload_valid);\r",
              "console.log(\"Total Passed   : \" + body.total_passed);\r",
              "console.log(\"Total Warnings : \" + body.total_warnings);\r",
              "console.log(\"Total Errors   : \" + body.total_errors);\r",
              "\r",
              "if (body.total_errors > 0) {\r",
              "    console.log(\"--- ERRORS ---\");\r",
              "    body.errors.forEach(function (err, i) {\r",
              "        console.log((i + 1) + \". \" + err);\r",
              "    });\r",
              "}\r",
              "\r",
              "if (body.total_warnings > 0) {\r",
              "    console.log(\"--- WARNINGS ---\");\r",
              "    body.warnings.forEach(function (warn, i) {\r",
              "        console.log((i + 1) + \". \" + warn);\r",
              "    });\r",
              "}\r",
              "\r",
              "if (body.total_passed > 0) {\r",
              "    console.log(\"--- PASSED ---\");\r",
              "    body.passed.forEach(function (ok, i) {\r",
              "        console.log((i + 1) + \". \" + ok);\r",
              "    });\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": []
        },
        "url": {
          "raw": "https://dev-tms.eurekare.net:61012/resources/test_ws/ivan/postmanTesting/test_postman_validation.php",
          "protocol": "https",
          "host": [
            "dev-tms",
